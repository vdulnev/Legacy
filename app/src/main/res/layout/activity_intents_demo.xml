<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <include layout="@layout/view_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/header_intents_demo"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <!-- Explicit Intents -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_explicit_intents"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/colorSurface"
                android:padding="8dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_explicit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_go_lifecycle" />

            </LinearLayout>

            <!-- Implicit Intents -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_implicit_intents"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/colorSurface"
                android:padding="8dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_browser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_open_browser"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_share"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_share_text"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_dial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_dial_number" />

            </LinearLayout>

            <!-- Pass Data -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_pass_data"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/colorSurface"
                android:padding="8dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/edit_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_enter_name"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_send_data"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_send_data"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/text_received"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_received_data"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp"
                    android:padding="8dp"
                    android:background="#F5F5F5" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>