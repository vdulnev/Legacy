<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <include layout="@layout/view_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/header_xml_layouts_demo"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="16dp" />

            <!-- LinearLayout Vertical -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_linearlayout_vertical"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/colorSurface"
                android:padding="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/item_1"
                    android:padding="8dp"
                    android:textColor="@color/colorTextPrimary"
                    android:background="#FAFAFA" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/item_2"
                    android:padding="8dp"
                    android:textColor="@color/colorTextPrimary"
                    android:background="#FAFAFA" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/item_3"
                    android:padding="8dp"
                    android:textColor="@color/colorTextPrimary"
                    android:background="#FAFAFA" />

            </LinearLayout>

            <!-- LinearLayout Horizontal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_linearlayout_horizontal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/item_1"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:background="@color/topic_red" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/item_2"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:background="@color/topic_blue" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/item_3"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:background="@color/topic_green" />

            </LinearLayout>

            <!-- RelativeLayout -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_relativelayout"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/colorSurface"
                android:padding="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/rel_top_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pos_top_left"
                    android:textColor="@color/colorTextPrimary"
                    android:padding="4dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/rel_top_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pos_top_right"
                    android:textColor="@color/colorTextPrimary"
                    android:padding="4dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true" />

                <TextView
                    android:id="@+id/rel_center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pos_center"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:layout_centerInParent="true" />

                <TextView
                    android:id="@+id/rel_bottom_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pos_bottom_left"
                    android:textColor="@color/colorTextPrimary"
                    android:padding="4dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/rel_bottom_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pos_bottom_right"
                    android:textColor="@color/colorTextPrimary"
                    android:padding="4dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true" />

            </RelativeLayout>

            <!-- ConstraintLayout -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_constraintlayout"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/colorSurface"
                android:padding="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/constraint_a"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/constraint_a"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/topic_red"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/constraint_b"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/constraint_b"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/constraint_b"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/topic_blue"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/constraint_a"
                    app:layout_constraintEnd_toStartOf="@+id/constraint_c"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/constraint_c"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/constraint_c"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@color/topic_green"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/constraint_b"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginStart="4dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>